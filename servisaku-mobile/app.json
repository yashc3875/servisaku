{
  "expo": {
    "name": "ServisAku",
    "slug": "servisaku-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "servisaku",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B6E4F",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "my.servisaku.app",
      "config": {
        "googleMapsApiKey": "MOCK_GOOGLE_MAPS_API_KEY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ServisAku uses your location to show nearby services and track your partner.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "my.servisaku.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B6E4F"
      },
      "config": {
        "googleMaps": {
          "apiKey": "MOCK_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ServisAku uses your location to show nearby services and track your partner."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
