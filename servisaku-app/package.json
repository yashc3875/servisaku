{
  "name": "servisaku-app",
  "version": "0.1.0",
  "private": true,
  "description": "ServisAku Android/iOS app — a Capacitor shell that reuses the ServisAku web UI so the app and website look identical.",
  "scripts": {
    "copy:web": "node scripts/copy-web.mjs",
    "build:web": "npm --prefix ../ run build && npm run copy:web",
    "sync": "cap sync",
    "assets": "capacitor-assets generate --assetPath assets",
    "add:android": "cap add android",
    "add:ios": "cap add ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android",
    "run:ios": "cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.0"
  }
}
